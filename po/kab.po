#: src/LYStyle.c:332
#, c-format
msgid ""
"Syntax Error parsing style in lss file:\n"
"[%s]\n"
"The line must be of the form:\n"
"OBJECT:MONO:COLOR (ie em:bold:brightblue:white)\n"
"where OBJECT is one of EM,STRONG,B,I,U,BLINK etc.\n"
"\n"
msgstr ""
"Tuccḍa deg tseddast deg ufaylu lss:\n"
"[%s]\n"
"Izirig ilaq ad yili s talɣa:\n"
"OBJECT:MONO:COLOR (ie em:bold:brightblue:white)\n"
"anida OBJECT d yiwen seg EM,STRONG,B,I,U,BLINK tgr.\n"
"\n"

#: src/LYStyle.c:941
#, c-format
msgid ""
"\n"
"Lynx file \"%s\" is not available.\n"
"\n"
msgstr ""
"\n"
"Afaylu n Lynx \"%s\" ulac-it.\n"
"\n"

