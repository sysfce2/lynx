#. #define HELP
#: LYMessages.c:47
msgid "Commands: Use arrow keys to move, '?' for help, 'q' to quit, '<-' to go back."
msgstr "Anẓaden: Seqdec tiqeffalin n tnila i usenkez n '?' i tallalt, 'q' i tuffɣa, '<-' i tuɣalin ɣer deffir."

#. #define MOREHELP
#: LYMessages.c:49
msgid "-- press space for more, use arrow keys to move, '?' for help, 'q' to quit."
msgstr "-- sit ɣef tallunt i wugar, seqdec tiqeffalin n tnila i usenkez n '?' i tallalt, 'q' i tuffɣa, '<-' i tuɣalin ɣer deffir."

#: LYMessages.c:50
msgid "-- press space for next page --"
msgstr "-- sit ɣef tallunt i usebter uḍfir --"

#: LYMessages.c:51
msgid "URL too long"
msgstr "URL ɣezzif aṭas"

